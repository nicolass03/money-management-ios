// Copy to Secrets.xcconfig and fill in values from your Supabase project
// (same as NEXT_PUBLIC_SUPABASE_URL / NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY in the web app)
//
// IMPORTANT: xcconfig treats "//" as a comment. Use https:/$()/host... not https://host...

SUPABASE_URL = https:/$()/YOUR_PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY = sb_publishable_YOUR_KEY_HERE
API_URL = http:/$()/127.0.0.1:8080
