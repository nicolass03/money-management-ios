    "This closes the budget and moves it to history. Projections will use actual spent instead of the reserved total. You won't be able to add more expenses." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This closes the budget and moves it to history. Projections will use actual spent instead of the reserved total. You won't be able to add more expenses."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto cierra el presupuesto y lo mueve al historial. Las proyecciones usarán el gasto real en lugar del total reservado. No podrás agregar más gastos."
